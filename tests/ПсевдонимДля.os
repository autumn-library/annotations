#Использовать "."
#Использовать asserts

&Тест
Процедура ПсевдонимПереноситПереданноеЗначениеВМетаАннотацию() Экспорт

	// Дано
	Метод = НайтиМетод("МетодСПсевдонимом");
	КонтейнерАннотаций = ПодготовитьКонтейнер();

	// Когда
	РазворачивательАннотаций = КонтейнерАннотаций.ПолучитьРазворачивательАннотаций();
	РазворачивательАннотаций.РазвернутьАннотацииСвойства(Метод, Тип("ВладелецАннотаций"));

	// Тогда
	Ожидаем.Что(Метод.Аннотации.Количество()).Равно(2);

	ЦельАннотация = РаботаСАннотациями.НайтиАннотацию(Метод.Аннотации, "Цель");
	Ожидаем.Что(ЦельАннотация).ИмеетТип("СтрокаТаблицыЗначений");

	Значение = РаботаСАннотациями.ПолучитьЗначениеПараметраАннотации(ЦельАннотация, "Значение");
	Ожидаем.Что(Значение).Равно("переопределённое значение");

	ОбъектЦели = КонтейнерАннотаций.ПолучитьОпределениеАннотации("Цель").СоздатьОбъектАннотации(ЦельАннотация);
	Ожидаем.Что(ОбъектЦели.УстановленноеЗначение).Равно("переопределённое значение");

КонецПроцедуры

&Тест
Процедура ПсевдонимНеПереноситЗначениеПоУмолчаниюВМетаАннотацию() Экспорт

	// Дано
	Метод = НайтиМетод("МетодСПсевдонимомПоУмолчанию");
	КонтейнерАннотаций = ПодготовитьКонтейнер();

	// Когда
	РазворачивательАннотаций = КонтейнерАннотаций.ПолучитьРазворачивательАннотаций();
	РазворачивательАннотаций.РазвернутьАннотацииСвойства(Метод, Тип("ВладелецАннотаций"));

	// Тогда
	ЦельАннотация = РаботаСАннотациями.НайтиАннотацию(Метод.Аннотации, "Цель");
	Ожидаем.Что(ЦельАннотация).ИмеетТип("СтрокаТаблицыЗначений");

	// Значение параметра не было передано явно, поэтому значение по умолчанию композита
	// не переносится — мета-аннотация использует собственное значение по умолчанию.
	ПараметрЗначение = РаботаСАннотациями.ПолучитьПараметрАннотации(ЦельАннотация, "Значение");
	Ожидаем.Что(ПараметрЗначение).Равно(Неопределено);

	ОбъектЦели = КонтейнерАннотаций.ПолучитьОпределениеАннотации("Цель").СоздатьОбъектАннотации(ЦельАннотация);
	Ожидаем.Что(ОбъектЦели.УстановленноеЗначение).Равно("значение по умолчанию");

КонецПроцедуры

&Тест
Процедура ПсевдонимПереноситЗначениеПоУмолчаниюВМетаАннотациюПриОптИн() Экспорт

	// Дано
	Метод = НайтиМетод("МетодСПсевдонимомСПереносомЗначенияПоУмолчанию");
	КонтейнерАннотаций = ПодготовитьКонтейнер();

	// Когда
	РазворачивательАннотаций = КонтейнерАннотаций.ПолучитьРазворачивательАннотаций();
	РазворачивательАннотаций.РазвернутьАннотацииСвойства(Метод, Тип("ВладелецАннотаций"));

	// Тогда
	ЦельАннотация = РаботаСАннотациями.НайтиАннотацию(Метод.Аннотации, "Цель");
	Ожидаем.Что(ЦельАннотация).ИмеетТип("СтрокаТаблицыЗначений");

	Значение = РаботаСАннотациями.ПолучитьЗначениеПараметраАннотации(ЦельАннотация, "Значение");
	Ожидаем.Что(Значение).Равно("значение композита по умолчанию");

	ОбъектЦели = КонтейнерАннотаций.ПолучитьОпределениеАннотации("Цель").СоздатьОбъектАннотации(ЦельАннотация);
	Ожидаем.Что(ОбъектЦели.УстановленноеЗначение).Равно("значение композита по умолчанию");

КонецПроцедуры

&Тест
Процедура ПсевдонимПереноситВсеЗначенияПовторяемогоПараметра() Экспорт

	// Дано
	Метод = НайтиМетод("МетодСПовторяемымПсевдонимом");
	КонтейнерАннотаций = ПодготовитьКонтейнер();

	// Когда
	РазворачивательАннотаций = КонтейнерАннотаций.ПолучитьРазворачивательАннотаций();
	РазворачивательАннотаций.РазвернутьАннотацииСвойства(Метод, Тип("ВладелецАннотаций"));

	// Тогда
	ЦельАннотация = РаботаСАннотациями.НайтиАннотацию(Метод.Аннотации, "ЦельПовторяемая");
	Ожидаем.Что(ЦельАннотация).ИмеетТип("СтрокаТаблицыЗначений");

	Значения = РаботаСАннотациями.ПолучитьЗначенияПараметровАннотации(ЦельАннотация, "Значение");
	Ожидаем.Что(Значения.Количество()).Равно(2);
	Ожидаем.Что(Значения[0]).Равно("первое");
	Ожидаем.Что(Значения[1]).Равно("второе");

	ОбъектЦели = КонтейнерАннотаций.ПолучитьОпределениеАннотации("ЦельПовторяемая").СоздатьОбъектАннотации(ЦельАннотация);
	Ожидаем.Что(ОбъектЦели.УстановленныеЗначения.Количество()).Равно(2);
	Ожидаем.Что(ОбъектЦели.УстановленныеЗначения[0]).Равно("первое");
	Ожидаем.Что(ОбъектЦели.УстановленныеЗначения[1]).Равно("второе");

КонецПроцедуры

Функция ПодготовитьКонтейнер()
	КонтейнерАннотаций = Новый КонтейнерАннотаций();
	КонтейнерАннотаций.ДобавитьАннотацию(Тип("АннотацияЦель"));
	КонтейнерАннотаций.ДобавитьАннотацию(Тип("АннотацияКомпозит"));
	КонтейнерАннотаций.ДобавитьАннотацию(Тип("АннотацияКомпозитСПереносом"));
	КонтейнерАннотаций.ДобавитьАннотацию(Тип("АннотацияЦельПовторяемая"));
	КонтейнерАннотаций.ДобавитьАннотацию(Тип("АннотацияКомпозитПовторяемый"));
	Возврат КонтейнерАннотаций;
КонецФункции

Функция НайтиМетод(ИмяМетода)

	Рефлектор = Новый Рефлектор();
	ТаблицаМетодов = Рефлектор.ПолучитьТаблицуМетодов(Тип("ВладелецАннотаций"));
	Возврат ТаблицаМетодов.Найти(ИмяМетода, "Имя");

КонецФункции
